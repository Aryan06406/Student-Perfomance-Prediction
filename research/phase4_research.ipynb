    "def make_pipeline(snapshot: str, task: str, estimator):\n",
    "    \"\"\"\n",
    "    Returns a full sklearn Pipeline:\n",
    "      encode → engineer → select (snapshot+task) → scale → model\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    snapshot  : 'before_ia' | 'after_ia1' | 'after_ia2'\n",
    "    task      : 'gpa' | 'dropout' | 'archetype'\n",
    "    estimator : any sklearn-compatible estimator\n",
    "    \"\"\"\n",
    "    \n",
    "    return Pipeline([\n",
    "        ('encode',   EncodingTransformer()),\n",
    "        ('engineer', FeatureEngineeringTransformer()),\n",
    "        ('impute',   NumericImputer()),\n",
    "        ('select',   SnapshotSelector(snapshot=snapshot, task=task)),\n",
    "        ('scale',    StandardScaler()),\n",
    "        ('model',    estimator),\n",
    "    ])"
   ]
  },

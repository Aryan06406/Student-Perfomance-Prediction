    "class SnapshotSelector(BaseEstimator, TransformerMixin):\n",
    "    \"\"\"\n",
    "    Selects the exact feature set for a given (snapshot, task) combination.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    snapshot : 'before_ia' | 'after_ia1' | 'after_ia2'\n",
    "    task     : 'gpa' | 'dropout' | 'archetype'\n",
    "    \"\"\"\n",
    "    def __init__(self, snapshot: str, task: str):\n",
    "        self.snapshot = snapshot\n",
    "        self.task     = task\n",
    "\n",
    "    def fit(self, X, y=None):\n",
    "        # Pool for this snapshot\n",
    "        if self.task == 'archetype':\n",
    "            pool = ARCHETYPE_POOL[self.snapshot]\n",
    "        else:\n",
    "            pool = SNAPSHOT_POOL[self.snapshot]\n",
    "\n",
    "        # Remove always-excluded leakage columns\n",
    "        exclude = set(ALWAYS_EXCLUDE)\n",
    "\n",
    "        # Remove per-model extra exclusions\n",
    "        key = (self.snapshot, self.task)\n",
    "        if key in EXTRA_EXCLUDE:\n",
    "            exclude |= EXTRA_EXCLUDE[key]\n",
    "\n",
    "        self.cols_ = [c for c in pool\n",
    "                      if c in X.columns and c not in exclude]\n",
    "        return self\n",
    "\n",
    "    def transform(self, X, y=None):\n",
    "        return X[self.cols_].copy()\n",
    "\n",
    "    @property\n",
    "    def feature_names_out_(self):\n",
    "        return self.cols_"
   ]

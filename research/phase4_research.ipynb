    "OPTIMAL_THRESHOLDS = {}\n",
    "\n",
    "print(\"\\nOptimal thresholds for dropout classification:\")\n",
    "for name, pipe in PIPELINES.items():\n",
    "    snapshot, task, model_name = name.split('__')\n",
    "    if task != 'dropout':\n",
    "        continue\n",
    "\n",
    "    probs = pipe.predict_proba(df_test)[:, 1]\n",
    "    precision, recall, thresholds = precision_recall_curve(y_drop_test, probs)\n",
    "\n",
    "    # precision_recall_curve returns len(thresholds) = len(precision) - 1\n",
    "    # so zip to align\n",
    "    f1_scores = 2 * (precision[:-1] * recall[:-1]) / (precision[:-1] + recall[:-1] + 1e-9)\n",
    "    best_idx  = np.argmax(f1_scores)\n",
    "\n",
    "    OPTIMAL_THRESHOLDS[name] = {\n",
    "        'threshold' : float(thresholds[best_idx]),\n",
    "        'best_f1'   : float(f1_scores[best_idx]),\n",
    "        'precision' : float(precision[best_idx]),\n",
    "        'recall'    : float(recall[best_idx]),\n",
    "    }\n",
    "    print(f\"{name:<45}  threshold={thresholds[best_idx]:.4f}  \"\n",
    "          f\"F1={f1_scores[best_idx]:.4f}  \"\n",
    "          f\"P={precision[best_idx]:.3f}  R={recall[best_idx]:.3f}\")"
   ]

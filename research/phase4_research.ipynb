    "class EncodingTransformer(BaseEstimator, TransformerMixin):\n",
    "    \"\"\"\n",
    "    Handles all categorical encoding:\n",
    "      - OrdinalEncoder  for Gender, ParentalEducation, SchoolType\n",
    "      - pd.get_dummies   for Locale, Race, Archetype_Prev,\n",
    "                         Intervention_Applied, Shock_Event\n",
    "    Fit on train, transform on any split — no leakage.\n",
    "    \"\"\"\n",
    "    ORDINAL_MAPS = {\n",
    "        'Gender'           : {'Male': 0, 'Female': 1},\n",
    "        'ParentalEducation': {'<HS': 0, 'HS': 1, 'SomeCollege': 2, 'Bachelors+': 3},\n",
    "        'SchoolType'       : {'Public': 0, 'Private': 1},\n",
    "    }\n",
    "    OHE_PREFIXES = ['Locale', 'Race', 'Archetype_Prev',\n",
    "                    'Intervention_Applied', 'Shock_Event']\n",
    "\n",
    "    def fit(self, X, y=None):\n",
    "        X = X.copy()\n",
    "        # Identify which OHE base columns exist (pre-expansion)\n",
    "        self._ohe_cols = [c for c in self.OHE_PREFIXES if c in X.columns]\n",
    "        # Capture dummies column names from train set for alignment\n",
    "        if self._ohe_cols:\n",
    "            dummies = pd.get_dummies(X[self._ohe_cols].astype(str),\n",
    "                                     prefix=self._ohe_cols, drop_first=True)\n",
    "            self._ohe_feature_names = list(dummies.columns)\n",
    "        else:\n",
    "            self._ohe_feature_names = []\n",
    "        return self\n",
    "\n",
    "    def transform(self, X, y=None):\n",
    "        X = X.copy()\n",
    "        # Ordinal\n",
    "        for col, mapping in self.ORDINAL_MAPS.items():\n",
    "            if col in X.columns:\n",
    "                X[col] = X[col].map(mapping).fillna(-1).astype(int)\n",
    "        # OHE\n",
    "        if self._ohe_cols:\n",
    "            present = [c for c in self._ohe_cols if c in X.columns]\n",
    "            dummies = pd.get_dummies(X[present].astype(str),\n",
    "                                     prefix=present, drop_first=True)\n",
    "            # Align to train columns\n",
    "            dummies = dummies.reindex(columns=self._ohe_feature_names,\n",
    "                                      fill_value=0)\n",
    "            X = X.drop(columns=present, errors='ignore')\n",
    "            X = pd.concat([X.reset_index(drop=True),\n",
    "                           dummies.reset_index(drop=True)], axis=1)\n",
    "        return X"
   ]
  },

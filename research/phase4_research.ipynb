    "def eval_gpa(pipeline, df_test, y_test, label):\n",
    "    preds = pipeline.predict(df_test)\n",
    "    mse   = mean_squared_error(y_test, preds)\n",
    "    rmse  = np.sqrt(mse)\n",
    "    mae   = mean_absolute_error(y_test, preds)\n",
    "    r2    = r2_score(y_test, preds)\n",
    "    print(f\"\\n── {label} ──\")\n",
    "    print(f\"  RMSE: {rmse:.4f}  MAE: {mae:.4f}  R²: {r2:.4f}\")\n",
    "    return preds\n",
    "\n",
    "def eval_dropout(pipeline, df_test, y_test, label, threshold=0.30):\n",
    "    probs  = pipeline.predict_proba(df_test)[:, 1]\n",
    "    preds  = (probs >= threshold).astype(int)\n",
    "    auc    = roc_auc_score(y_test, probs)\n",
    "    print(f\"\\n── {label}  (threshold={threshold}) ──\")\n",
    "    print(f\"  AUC: {auc:.4f}\")\n",
    "    print(classification_report(y_test, preds, digits=3))\n",
    "    return probs, preds\n",
    "\n",
    "def eval_archetype(pipeline, df_test, y_test, label):\n",
    "    preds = pipeline.predict(df_test)\n",
    "    print(f\"\\n── {label} ──\")\n",
    "    print(classification_report(y_test, preds,\n",
    "          target_names=le_archetype.classes_, digits=3))\n",
    "    return preds"
   ]

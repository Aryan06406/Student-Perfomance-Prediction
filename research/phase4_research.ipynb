    "class NumericImputer(BaseEstimator, TransformerMixin):\n",
    "        \"\"\"\n",
    "        Imputes median on numeric columns only.\n",
    "        Leaves string/object columns completely untouched.\n",
    "        Preserves DataFrame format for SnapshotSelector.\n",
    "        \"\"\"\n",
    "        def fit(self, X, y=None):\n",
    "            self._num_cols = X.select_dtypes(include='number').columns.tolist()\n",
    "            self._medians  = X[self._num_cols].median()\n",
    "            return self\n",
    "\n",
    "        def transform(self, X, y=None):\n",
    "            X = X.copy()\n",
    "            for col in self._num_cols:\n",
    "                if col in X.columns:\n",
    "                    X[col] = X[col].fillna(self._medians.get(col, 0))\n",
    "            return X"
   ]
  },

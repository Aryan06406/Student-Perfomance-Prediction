    "def temporal_cv_eval(pipeline, df_train, y_train, folds, task='gpa', threshold=0.30):\n",
    "    all_preds, all_trues = [], []\n",
    "    for tr_idx, va_idx in folds:\n",
    "        pipe_fold = clone(pipeline)\n",
    "        pipe_fold.fit(df_train.loc[tr_idx], y_train.loc[tr_idx])\n",
    "\n",
    "        if task == 'dropout':\n",
    "            probs = pipe_fold.predict_proba(df_train.loc[va_idx])[:, 1]\n",
    "            preds = (probs >= threshold).astype(int)\n",
    "        else:\n",
    "            preds = pipe_fold.predict(df_train.loc[va_idx])\n",
    "\n",
    "        all_preds.extend(preds)\n",
    "        all_trues.extend(y_train.loc[va_idx])\n",
    "\n",
    "    return np.array(all_trues), np.array(all_preds)"
   ]
  },

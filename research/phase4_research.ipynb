    "SNAPSHOT_POOL = {\n",
    "    'before_ia'  : BASE,\n",
    "    'after_ia1'  : BASE + IA1_SIGNALS,\n",
    "    'after_ia2'  : BASE + IA1_SIGNALS + IA2_SIGNALS,\n",
    "}\n",
    "\n",
    "# Archetype models use a deliberately narrower pool (no static/historical bulk)\n",
    "ARCHETYPE_POOL = {\n",
    "    'before_ia' : (BEHAVIORAL + DYNAMIC + SHOCK\n",
    "                   + ['Prev_GPA', \n",
    "                      'Archetype_Prev_elite', 'Archetype_Prev_vulnerable',\n",
    "                      'Archetype_Prev_disengaged', 'Archetype_Prev_fading_star',\n",
    "                      'Archetype_Prev_late_bloomer', 'Archetype_Prev_pragmatist']),\n",
    "    'after_ia1': (BEHAVIORAL + DYNAMIC + SHOCK + IA1_SIGNALS\n",
    "                  + ['Prev_GPA', 'Archetype_Prev_elite', 'Archetype_Prev_vulnerable']),\n",
    "    'after_ia2': (BEHAVIORAL + DYNAMIC + SHOCK + INTERVENTION\n",
    "                  + IA2_SIGNALS + ['IA1_Score']),\n",
    "}"
   ]

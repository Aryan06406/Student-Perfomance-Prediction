    "# ── GPA ───────────────────────────────────────────────────────────────────────\n",
    "for snapshot in ['before_ia', 'after_ia1', 'after_ia2']:\n",
    "    key = f\"{snapshot}__gpa__lgbm\"\n",
    "    trues, preds = temporal_cv_eval(PIPELINES[key], df_train, y_gpa_train,\n",
    "                                    temporal_folds, task='gpa')\n",
    "    rmse = np.sqrt(mean_squared_error(trues, preds))\n",
    "    r2   = r2_score(trues, preds)\n",
    "    print(f\"Temporal CV  {key:<35}  RMSE: {rmse:.4f}  R²: {r2:.4f}\")\n",
    "\n",
    "# ── Dropout ───────────────────────────────────────────────────────────────────\n",
    "for snapshot in ['before_ia', 'after_ia1', 'after_ia2']:\n",
    "    for model_name, threshold in [('logistic', 0.30), ('lgbm_recall', 0.30), ('lgbm_precision', 0.88)]:\n",
    "        key = f\"{snapshot}__dropout__{model_name}\"\n",
    "        trues, preds = temporal_cv_eval(PIPELINES[key], df_train, y_drop_train,\n",
    "                                        temporal_folds, task='dropout',\n",
    "                                        threshold=threshold)\n",
    "        print(f\"\\nTemporal CV  {key}\")\n",
    "        print(classification_report(trues, preds, digits=3))\n",
    "\n",
    "# ── Archetype ─────────────────────────────────────────────────────────────────\n",
    "for snapshot in ['before_ia', 'after_ia1', 'after_ia2']:\n",
    "    key = f\"{snapshot}__archetype__lgbm\"\n",
    "    trues, preds = temporal_cv_eval(PIPELINES[key], df_train,\n",
    "                                    pd.Series(y_arch_train),\n",
    "                                    temporal_folds, task='archetype')\n",
    "    print(f\"\\nTemporal CV  {key}\")\n",
    "    print(classification_report(trues, preds,\n",
    "          target_names=le_archetype.classes_, digits=3))"
